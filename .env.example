# =============================================================================
# PrismA - Secure Journal App — Environment Configuration
# Copy this file to .env and edit as needed.
# All values shown are the defaults.
# =============================================================================

# -- Paths -------------------------------------------------------------------
# MODEL_PATH=./app/models
# DB_PATH=./app/database/journal.db
# CHROMA_PATH=./app/database/chroma

# -- Flask -------------------------------------------------------------------
# SECRET_KEY=dev-secret-key-change-in-production
# DEBUG_MODE=true

# -- Entry limits ------------------------------------------------------------
# MAX_ENTRY_LENGTH=50000

# -- LLM Provider Selection --------------------------------------------------
# Choose between "ollama" or "lmstudio" for AI features
# LLM_PROVIDER=ollama

# -- Ollama (LLM) -----------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
# OLLAMA_TIMEOUT=120

# -- LM Studio (Alternative LLM via OpenAI-compatible API) ------------------
# LM Studio provides a local OpenAI-compatible server
# Download: https://lmstudio.ai
# Start the local server in LM Studio, then configure below
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=local-model           # Use the model ID shown in LM Studio
# LMSTUDIO_TIMEOUT=120

# -- Whisper (Speech-to-text) ------------------------------------------------
# Model sizes: tiny, base, small, medium, large
# Larger = more accurate but slower and more VRAM
# WHISPER_MODEL=base

# -- Image Generation (ComfyUI - RECOMMENDED) ---------------------------------
# ComfyUI provides high-quality AI-generated artwork for journal entries
# Installation: https://github.com/comfyanonymous/ComfyUI
# Start with: python main.py --listen --port 8188
#
# COMFY_ENABLED=true
# COMFY_API_URL=http://127.0.0.1:8188
# COMFY_WORKFLOW_MODE=refiner          # "base" (faster) or "refiner" (better quality)
# COMFY_BASE_MODEL=sd_xl_base_1.0.safetensors
# COMFY_REFINER_MODEL=sd_xl_refiner_1.0.safetensors

# -- Stable Diffusion WebUI (Legacy - optional) ------------------------------
# Fallback option if ComfyUI is not available
# Uses AUTOMATIC1111 or similar WebUI API
# SD_ENDPOINT=http://localhost:7860
# SD_ENABLED=false
# SD_DEFAULT_STYLE=minimalist abstract

# -- Embeddings / ChromaDB --------------------------------------------------
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CHROMA_COLLECTION=journal_entries

# -- UI theme ----------------------------------------------------------------
# Options: ocean, forest, sunset, lavender, slate, sand, berry, monochrome
# COLOR_THEME=monochrome

# -- Tag Suggestions ---------------------------------------------------------
# TAG_ENABLED=true
# TAG_MODEL=qwen3:0.6b
# TAG_MIN_LENGTH=50
# TAG_MAX_SUGGESTIONS=7
# TAG_DEBOUNCE_MS=500
